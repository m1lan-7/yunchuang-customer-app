PORT=4184
HOST=0.0.0.0
NODE_ENV=production

# Feishu web app SSO. Configure these for login-free access inside Feishu.
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Optional fallback password login. Leave empty when using Feishu SSO.
# APP_PASSWORD=
# APP_PASSWORD_HASH=

# Optional. If omitted, the app uses data/customers.json.
DATABASE_URL=postgres://user:password@host:5432/yunchuang
# Set PGSSLMODE=disable only when your Postgres does not require SSL.
# PGSSLMODE=disable
